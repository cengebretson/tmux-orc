#!/usr/bin/env bash
set -euo pipefail

echo "→ tidy"
go mod tidy
if ! git diff --quiet go.mod go.sum; then
  echo "go.mod or go.sum was updated by go mod tidy — stage the changes and re-commit"
  exit 1
fi

echo "→ fmt"
unformatted=$(gofmt -l ./cmd ./internal)
if [ -n "$unformatted" ]; then
  gofmt -w ./cmd ./internal
  echo "gofmt reformatted: $unformatted — stage the changes and re-commit"
  exit 1
fi

echo "→ lint"
golangci-lint run ./...

echo "→ test"
go test ./...
